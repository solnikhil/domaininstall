{
  "name": "domaininstall",
  "version": "0.0.1",
  "description": "Install a package by domain name. The domain owner proves the mapping with a DNS TXT record; domaininstall resolves it, shows you exactly what will be installed, and hands off to your package manager.",
  "type": "module",
  "bin": {
    "di": "dist/cli.js",
    "domaininstall": "dist/cli.js",
    "dnstall": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "npm run build && node --experimental-strip-types scripts/smoke.ts",
    "test:e2e": "npm run build && node --experimental-strip-types scripts/e2e.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dns",
    "install",
    "package-manager",
    "npm",
    "typosquatting",
    "provenance",
    "dnslink",
    "supply-chain"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
